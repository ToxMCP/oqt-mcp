{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ToxMCP/oqt-mcp/blob/main/schemas/oqtWorkflowRecord.v1.json",
  "title": "O-QT Workflow Record v1",
  "description": "Portable record for a single O-QT workflow execution. This is a handoff object, not a final decision object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "module",
    "workflowId",
    "inputIdentifier",
    "searchType",
    "rootEntity",
    "packageSemantics",
    "toolchain",
    "artifacts",
    "attachments",
    "executionMetadata",
    "provenance",
    "reproducibility"
  ],
  "properties": {
    "schemaName": {
      "const": "oqtWorkflowRecord"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "module": {
      "const": "oqt-mcp"
    },
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "inputIdentifier": {
      "$ref": "#/$defs/inputIdentifier"
    },
    "searchType": {
      "type": "string",
      "enum": ["auto", "name", "cas", "smiles"]
    },
    "context": {
      "type": ["string", "null"]
    },
    "rootEntity": {
      "$ref": "#/$defs/rootEntity"
    },
    "packageSemantics": {
      "$ref": "#/$defs/packageSemantics"
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryEntrypoint", "helperTools", "toolboxCompatibility"],
      "properties": {
        "primaryEntrypoint": {
          "type": "string",
          "minLength": 1
        },
        "helperTools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "toolboxCompatibility": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json", "markdown", "pdf"],
      "properties": {
        "json": {
          "$ref": "#/$defs/artifact"
        },
        "markdown": {
          "$ref": "#/$defs/artifact"
        },
        "pdf": {
          "$ref": "#/$defs/artifact"
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachment"
      }
    },
    "executionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "assistantEnabled",
        "requestedProfilers",
        "requestedSimulators",
        "requestedQsarModels",
        "toolboxCallCount",
        "errors"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "partial", "not_found", "error", "review_required"]
        },
        "assistantEnabled": {
          "type": "boolean"
        },
        "requestedProfilers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requestedSimulators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requestedQsarModels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "toolboxCallCount": {
          "type": "integer",
          "minimum": 0
        },
        "toolboxTotalDurationMs": {
          "type": "number",
          "minimum": 0
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "reproducibility": {
      "$ref": "#/$defs/reproducibility"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "inputIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "resolvedName": {
          "type": "string"
        },
        "chemId": {
          "type": "string"
        }
      }
    },
    "rootEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "entityId"],
      "properties": {
        "entityType": {
          "type": "string",
          "enum": ["workflow_execution", "grouping_dossier"]
        },
        "entityId": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "packageSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "isReadOnly", "containsExternalReferences"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["working_bundle", "packaged_dossier"]
        },
        "isReadOnly": {
          "type": "boolean"
        },
        "containsExternalReferences": {
          "type": "boolean"
        },
        "purpose": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fieldName", "delivery", "mediaType", "description"],
      "properties": {
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "delivery": {
          "type": "string",
          "enum": ["inline", "file", "url"]
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "encoding": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "checksumSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "integrityNote": {
          "type": "string"
        }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "fieldName", "delivery", "mediaType", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["structured_log", "narrative_summary", "audit_report"]
        },
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "delivery": {
          "type": "string",
          "enum": ["inline", "file", "url"]
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "encoding": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "checksumSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "integrityNote": {
          "type": "string"
        }
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputHash", "toolchainVersions", "upstreamVersions", "executionTimestamp"],
      "properties": {
        "inputHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "snapshotHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "toolchainVersions": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "app": {"type": "string"},
            "python": {"type": "string"},
            "fastapi": {"type": "string"},
            "pydantic": {"type": "string"},
            "httpx": {"type": "string"}
          }
        },
        "upstreamVersions": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "apiVersions": {"type": "string"},
            "serverDate": {"type": "string"},
            "toolboxBuildVersion": {"type": "string"},
            "databaseVersion": {"type": "string"}
          }
        },
        "executionTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "randomSeed": {
          "type": ["string", "null"]
        }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "statusCode": {
          "type": "integer"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "attempts": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutProfile": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSystem", "generatedBy", "generatedAt", "repository"],
      "properties": {
        "sourceSystem": {
          "type": "string",
          "minLength": 1
        },
        "generatedBy": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "toolboxCompatibility": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "sourceTools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceRecord"
          }
        }
      }
    }
  }
}
